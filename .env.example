# TN InternFair — Environment Variables
# Copy this file to .env and fill in your values

# ===== DATABASE =====
MONGODB_URL=mongodb://localhost:27017
DB_NAME=tn_internfair

# ===== JWT AUTH =====
JWT_SECRET=tn_internfair_super_secret_key_change_in_production_min_32_chars
JWT_EXPIRE_HOURS=24

# ===== AI / CREWAI (Local Ollama) =====
# No API keys required for Ollama. Ensure Ollama is running locally with 'llama3' model.
# OLLAMA_BASE_URL=http://localhost:11434  (Default)

# ===== SERVER =====
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ===== FRONTEND =====
FRONTEND_URL=http://localhost:3000

# ===== MOCK MODE =====
# Set to "true" to always use mock data (no MongoDB needed)
USE_MOCK_DB=true
